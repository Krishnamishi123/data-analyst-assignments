      <column caption='delivery performance' datatype='string' name='[Calculation_1524515914469376]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min]&lt;=30 THEN &quot;FAST&quot;&#13;&#10;ELSE &quot;DELAYED&quot;&#13;&#10;END' />
      </column>
      <column caption='PROFIT/LOSS' datatype='string' name='[Calculation_1524515920683009]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit]&lt;0 THEN &quot;LOSS&quot;&#13;&#10;ELSE &quot;PROFIT&quot;&#13;&#10;END' />
